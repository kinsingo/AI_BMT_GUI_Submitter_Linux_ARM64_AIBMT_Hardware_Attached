{
  "inputs": {
    "input": [
      1,
      3,
      224,
      224
    ]
  },
  "calibration_num": 1024,
  "calibration_method": "ema",
  "default_loader": {
    "dataset_path": "./Calibration_Images_Classification",
    "file_extensions": [
      "jpeg",
      "jpg",
      "png",
      "JPEG"
    ],
    "preprocessings": [
      {
        "convertColor": {
          "form": "BGR2RGB"
        }
      },
      {
        "div": {
          "x": 255
        }
      },
      {
        "normalize": {
          "mean": [
            0.485,
            0.456,
            0.406
          ],
          "std": [
            0.229,
            0.224,
            0.225
          ]
        }
      },
      {
        "transpose": {
          "axis": [
            2,
            0,
            1
          ]
        }
      },
      {
        "expandDim": {
          "axis": 0
        }
      }
    ]
  }
}